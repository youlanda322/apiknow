<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>登录 - APIKnow 后台</title>
  <link rel="stylesheet" href="/admin/static/css/admin.css">
  <style>
    .login-page { display:flex; align-items:center; justify-content:center; min-height:100vh; background:#f5f3ef; }
    .login-box { width:380px; padding:40px 36px; background:#fff; border:1px solid #ddd8d0; border-radius:6px; box-shadow:0 2px 8px rgba(0,0,0,0.06); }
    .login-box h1 { margin:0 0 8px; font-size:24px; text-align:center; }
    .login-box p { margin:0 0 24px; color:#9a958e; font-size:14px; text-align:center; }
    .login-box label { display:block; margin-bottom:6px; font-size:14px; font-weight:600; }
    .login-box input { width:100%; height:42px; padding:0 12px; margin-bottom:16px; border:1px solid #ddd8d0; border-radius:4px; font-size:15px; }
    .login-box button { width:100%; height:44px; background:#c9a84c; color:#1a1f2e; border:none; border-radius:4px; font-size:16px; font-weight:700; cursor:pointer; }
    .login-box button:hover { background:#b8943a; }
    .login-error { padding:10px 14px; margin-bottom:16px; background:#fef5e0; border:1px solid #e8d5b5; border-radius:4px; color:#8a7030; font-size:13px; }
  </style>
</head>
<body>
<div class="login-page">
  <div class="login-box">
    <h1>APIKnow 后台</h1>
    <p>内容管理面板</p>
    <% if (error) { %>
    <div class="login-error"><%= error %></div>
    <% } %>
    <form method="POST">
      <label for="username">用户名</label>
      <input type="text" id="username" name="username" value="admin" required>
      <label for="password">密码</label>
      <input type="password" id="password" name="password" required>
      <button type="submit">登 录</button>
    </form>
  </div>
</div>
</body>
</html>
